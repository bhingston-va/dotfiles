{
  "permissions": {
    "allow": [
      "Bash(cd *)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(echo *)",
      "Bash(export *)",
      "Bash(grep *)",
      "Bash(find *)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git add *)",
      "Bash(git fetch *)",
      "Bash(git checkout *)",
      "Bash(git branch *)",
      "Bash(git stash*)",
      "Bash(git worktree *)",
      "Bash(npx nx *)",
      "Bash(npm run *)",
      "Bash(npm install*)",
      "Bash(go build *)",
      "Bash(go test *)",
      "Bash(go generate *)",
      "Bash(go install *)",
      "Bash(bq *)",
      "Edit(~/Projects/*)",
      "Edit(~/dotfiles/*)",
      "Edit(~/.claude/settings.json)"
    ],
    "additionalDirectories": [
      "~/Projects/"
    ]
  },
  "hooks": {
    "PermissionRequest": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/branch-check.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "vendasta-dev-agent-toolkit@vendasta-dev-agent-toolkit": true,
    "gopls-lsp@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "vendasta-dev-agent-toolkit": {
      "source": {
        "source": "git",
        "url": "https://github.com/vendasta/dev-agent-toolkit.git"
      },
      "autoUpdate": true
    }
  },
  "voiceEnabled": true
}
